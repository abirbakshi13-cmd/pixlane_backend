# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API → Project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Settings → API → Service role key  (starts with sb_secret_ in newer projects)
# NEVER expose this in client-side code or commit it to git.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your_service_role_key_here

# ── UPI payment ───────────────────────────────────────────────────────────────
# Used by netlify/functions/payment.js to build the upi://pay link.
# UPI_VPA is your GPay/UPI ID (e.g. yourname@okicici)
UPI_VPA=yourname@okicici
UPI_PAYEE_NAME=Pixlane Digital

# ── Google Calendar ───────────────────────────────────────────────────────────
# Used by netlify/functions/book.js to create calendar events.
# Create a service account in Google Cloud Console, download its JSON key,
# then share your calendar with the service account email ("Make changes to events").
GOOGLE_SA_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# Paste the private_key value from the JSON key file.
# In .env files, keep it as one line with literal \n between PEM lines.
GOOGLE_SA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
# The calendar ID to add events to (usually your Gmail address for the primary calendar)
GOOGLE_CALENDAR_ID=your-calendar-id@gmail.com

# ── Cloudflare Turnstile ──────────────────────────────────────────────────────
# Server-side secret for verifying Turnstile challenge tokens.
# Get from: Cloudflare Dashboard → Turnstile → your widget → Secret key.
# NEVER expose this in client-side code or commit it to git.
#
# For local dev you can use Cloudflare's always-pass test secret:
#   1x0000000000000000000000000000000AA
# Replace with your real secret before deploying to production.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your production domain. localhost:8888 is always allowed for netlify dev.
# Example: https://pixlane.in  (no trailing slash)
ALLOWED_ORIGIN=https://your-production-domain.com
